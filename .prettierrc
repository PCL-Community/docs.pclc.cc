{
    "endOfLine": "crlf",
    "semi": true,
    "singleQuote": false,
    "tabWidth": 4,
    "trailingComma": "es5",
    "bracketSameLine": true,
    "printWidth": 128,
    "overrides": [
        {
            "files": "**/index.ts",
            "options": {
                "printWidth": 2147483647
            }
        },
        {
            "files": "**/*.{yml,yaml}",
            "options": {
                "tabWidth": 2
            }
        }
    ]
}
